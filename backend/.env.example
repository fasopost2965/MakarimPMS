# En local avec docker compose (voir docker-compose.yml, port hôte 3307) :
DATABASE_URL="mysql://pms:pms@localhost:3307/pms_makarim"

# Secrets JWT — valeurs de développement ci-dessous uniquement, à générer
# aléatoirement (ex. openssl rand -base64 48) et à stocker en secret réel
# (jamais commit) pour tout déploiement au-delà du poste de dev local.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
