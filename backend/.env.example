# En local avec docker compose (voir docker-compose.yml, port hôte 3307) :
DATABASE_URL="mysql://pms:pms@localhost:3307/pms_makarim"

# Secrets JWT — valeurs de développement ci-dessous uniquement, à générer
# aléatoirement (ex. openssl rand -base64 48) et à stocker en secret réel
# (jamais commit) pour tout déploiement au-delà du poste de dev local.
# En NODE_ENV=production, le bootstrap (assertStrongSecrets, main.ts) refuse
# de démarrer si l'une de ces deux valeurs vaut encore le défaut ci-dessous.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# F9 — jeton mobile housekeeping (AuthService.loginMobile), même secret
# JWT_ACCESS_SECRET que ci-dessus (pas de secret parallèle), TTL propre et
# plus court adapté à la durée d'un service. Optionnelle, défaut 8h.
MOBILE_JWT_EXPIRES_IN="8h"

# Origine autorisée par CORS (credentials: true) — une seule origine, jamais
# un wildcard, puisque les requêtes portent des cookies/Authorization.
FRONTEND_URL="http://localhost:5173"

# NODE_ENV — absent ou différent de "production" par défaut (dev local, CI).
# En production : désactive la doc Swagger (/api/docs) et active la
# validation stricte des secrets JWT ci-dessus.
NODE_ENV="development"

# Redis (file BullMQ) — export/clôtures comptables lourds du module reporting
# exécutés en arrière-plan (voir modules/reporting/queues). Port hôte 6380
# avec docker compose (voir docker-compose.yml, un Redis natif peut déjà
# occuper 6379).
REDIS_HOST="localhost"
REDIS_PORT="6380"

# SMTP (module notifications, F7) — toutes optionnelles. Si SMTP_HOST est
# absent, MailerService ne lève jamais d'erreur : les emails sont
# journalisés (Logger) au lieu d'être envoyés, pour que le reste du flux
# (NotificationLog, queue, listeners) fonctionne sans serveur SMTP réel en
# dev/CI.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@makarim.test"

# Twilio (module notifications, F7 suite — canaux SMS/WhatsApp) — toutes
# optionnelles, même dégradation gracieuse que SMTP ci-dessus : si
# TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN sont absents, TwilioService ne lève
# jamais d'erreur, les SMS/WhatsApp sont journalisés (Logger) au lieu
# d'être envoyés. TWILIO_SMS_FROM est un numéro Twilio classique ;
# TWILIO_WHATSAPP_FROM est le numéro validé pour l'API WhatsApp Business
# (le préfixe "whatsapp:" est ajouté automatiquement, ne pas l'inclure ici).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM=""
